# PostgreSQL
POSTGRES_HOST=db           # Docker service name or hostname
POSTGRES_PORT=5432         # Default PostgreSQL port
POSTGRES_USER=             # Database user
POSTGRES_PASSWORD=         # Database password
POSTGRES_DB=backstage      # Database name

# App
APP_BASE_URL=              # Public URL (e.g. https://portal.example.com)

# GitHub
AUTH_GITHUB_CLIENT_ID=     # GitHub OAuth App client ID
AUTH_GITHUB_CLIENT_SECRET= # GitHub OAuth App client secret
GITHUB_TOKEN=              # Personal Access Token for API/integrations
GITHUB_ORG=                # GitHub organization name

# Microsoft Auth
AUTH_MICROSOFT_CLIENT_ID=     # Azure AD App Registration client ID
AUTH_MICROSOFT_CLIENT_SECRET= # Azure AD App Registration client secret
AUTH_MICROSOFT_TENANT_ID=     # Azure AD tenant ID

# Scaffolder
SCAFFOLDER_DEFAULT_EMAIL=  # Default author email for scaffolded commits

# Templates
PLATFORM_TEMPLATES_URL=    # URL to templates location YAML
